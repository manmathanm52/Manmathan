    *[class].main_content {padding-bottom:20px !important;}
    *[class].user_info {padding-top:10px !important;}
    *[class].hide tr td,
    *[class].hide td,
    *[class].hide {display:none !important;}
    *[class].cellphone *[class].display img {width:100% !important;}
    *[class].main_content img {width:auto !important;}
}

</style>

